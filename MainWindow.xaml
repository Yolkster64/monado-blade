<Window x:Class="MonadoBlade.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Monado Blade v2.0 - System Intelligence Platform" 
        Height="800" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="#FFFFFF"
        Icon="Resources/monado-blade-icon.ico">
    
    <Window.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="TextBlock" x:Key="HeaderText">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        
        <Style TargetType="TextBlock" x:Key="SubheaderText">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <StackPanel Grid.Column="0" Background="#252526" Padding="15">
            <TextBlock Text="MONADO BLADE" FontSize="16" FontWeight="Bold" Foreground="#0078D4" Margin="0,0,0,20"/>
            
            <Button Content="🏠 Dashboard" Style="{StaticResource ModernButton}" Margin="0,5" Background="#0078D4" Width="220" HorizontalAlignment="Left"/>
            <Button Content="🔒 Security Status" Style="{StaticResource ModernButton}" Margin="0,5" Background="#107C10" Width="220" HorizontalAlignment="Left"/>
            <Button Content="💾 Storage" Style="{StaticResource ModernButton}" Margin="0,5" Background="#DC7500" Width="220" HorizontalAlignment="Left"/>
            <Button Content="⚡ Performance" Style="{StaticResource ModernButton}" Margin="0,5" Background="#FF8C00" Width="220" HorizontalAlignment="Left"/>
            <Button Content="👤 Profiles" Style="{StaticResource ModernButton}" Margin="0,5" Background="#7635DC" Width="220" HorizontalAlignment="Left"/>
            <Button Content="☁️ Cloud Sync" Style="{StaticResource ModernButton}" Margin="0,5" Background="#0078D4" Width="220" HorizontalAlignment="Left"/>
            <Button Content="🎮 GPU Info" Style="{StaticResource ModernButton}" Margin="0,5" Background="#50E3C2" Width="220" HorizontalAlignment="Left"/>
            <Button Content="⚙️ Settings" Style="{StaticResource ModernButton}" Margin="0,5" Background="#6B6B6B" Width="220" HorizontalAlignment="Left"/>
            
            <Separator Margin="0,20"/>
            
            <TextBlock Text="System Info" FontSize="12" FontWeight="Bold" Foreground="#B0B0B0"/>
            <TextBlock Text="Status: Online" FontSize="11" Foreground="#107C10" Margin="0,5"/>
            <TextBlock Text="Version: 2.0.0" FontSize="11" Foreground="#B0B0B0" Margin="0,5"/>
            <TextBlock Text="GPU: NVIDIA 5090" FontSize="11" Foreground="#76B900" Margin="0,5"/>
            <TextBlock Text="Storage: 4TB NVMe" FontSize="11" Foreground="#FFB900" Margin="0,5"/>
        </StackPanel>

        <!-- Main Content Area -->
        <ScrollViewer Grid.Column="1" Background="#1E1E1E" Padding="30">
            <StackPanel>
                <!-- Header -->
                <StackPanel Margin="0,0,0,30">
                    <TextBlock Text="Monado Blade v2.0" Style="{StaticResource HeaderText}"/>
                    <TextBlock Text="Xenoblade-inspired system intelligence platform with military-grade security" Style="{StaticResource SubheaderText}"/>
                </StackPanel>

                <!-- Performance Metrics Row -->
                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Metric Card 1 -->
                    <Border Grid.Column="0" Background="#252526" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Boot Time" FontSize="12" Foreground="#B0B0B0"/>
                            <TextBlock Text="12s" FontSize="28" FontWeight="Bold" Foreground="#107C10"/>
                            <TextBlock Text="↓ 60% faster" FontSize="10" Foreground="#107C10"/>
                        </StackPanel>
                    </Border>

                    <!-- Metric Card 2 -->
                    <Border Grid.Column="1" Background="#252526" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="GPU Performance" FontSize="12" Foreground="#B0B0B0"/>
                            <TextBlock Text="8.7x" FontSize="28" FontWeight="Bold" Foreground="#FFB900"/>
                            <TextBlock Text="Faster inference" FontSize="10" Foreground="#FFB900"/>
                        </StackPanel>
                    </Border>

                    <!-- Metric Card 3 -->
                    <Border Grid.Column="2" Background="#252526" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="I/O Bandwidth" FontSize="12" Foreground="#B0B0B0"/>
                            <TextBlock Text="7-14GB/s" FontSize="28" FontWeight="Bold" Foreground="#50E3C2"/>
                            <TextBlock Text="NVMe speed" FontSize="10" Foreground="#50E3C2"/>
                        </StackPanel>
                    </Border>

                    <!-- Metric Card 4 -->
                    <Border Grid.Column="3" Background="#252526" CornerRadius="8" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Security Status" FontSize="12" Foreground="#B0B0B0"/>
                            <TextBlock Text="100%" FontSize="28" FontWeight="Bold" Foreground="#107C10"/>
                            <TextBlock Text="Protected" FontSize="10" Foreground="#107C10"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Features Section -->
                <TextBlock Text="Key Features" Style="{StaticResource HeaderText}" Margin="0,20,0,15"/>
                
                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Feature Box 1 -->
                    <Border Grid.Column="0" Background="#252526" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="⚡ Phase 10 Optimization" FontSize="14" FontWeight="Bold" Foreground="#FFB900"/>
                            <TextBlock Text="50% performance improvement across all subsystems" FontSize="11" Foreground="#B0B0B0" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Feature Box 2 -->
                    <Border Grid.Column="1" Background="#252526" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="🎮 GPU Acceleration" FontSize="14" FontWeight="Bold" Foreground="#50E3C2"/>
                            <TextBlock Text="Multi-GPU orchestration (NVIDIA, AMD, Intel)" FontSize="11" Foreground="#B0B0B0" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Feature Box 3 -->
                    <Border Grid.Column="2" Background="#252526" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="💾 Dual NVMe" FontSize="14" FontWeight="Bold" Foreground="#0078D4"/>
                            <TextBlock Text="4TB ultra-fast storage with ReFS + VHDX encryption" FontSize="11" Foreground="#B0B0B0" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Storage Architecture -->
                <TextBlock Text="Storage Architecture" Style="{StaticResource HeaderText}" Margin="0,20,0,15"/>
                
                <Border Background="#252526" CornerRadius="8" Padding="15" Margin="0,0,0,30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- DISK 0 -->
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="DISK 0 (2TB NVMe)" FontSize="12" FontWeight="Bold" Foreground="#0078D4"/>
                            <TextBlock Text="• C: Core OS (150GB)" FontSize="10" Foreground="#B0B0B0" Margin="0,5,0,0"/>
                            <TextBlock Text="• E: Common Software (300GB)" FontSize="10" Foreground="#B0B0B0"/>
                            <TextBlock Text="• X: Cross Tools (200GB)" FontSize="10" Foreground="#B0B0B0"/>
                            <TextBlock Text="• G: Dev Drive ReFS (350GB)" FontSize="10" Foreground="#B0B0B0"/>
                            <TextBlock Text="• V: Vault VHDX (150GB)" FontSize="10" Foreground="#B0B0B0"/>
                            <TextBlock Text="• K: Quarantine VHDX (150GB)" FontSize="10" Foreground="#B0B0B0"/>
                            <TextBlock Text="• Recovery (200GB)" FontSize="10" Foreground="#B0B0B0"/>
                        </StackPanel>

                        <!-- DISK 1 -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="DISK 1 (2TB NVMe)" FontSize="12" FontWeight="Bold" Foreground="#107C10"/>
                            <TextBlock Text="• Developer (100GB)" FontSize="10" Foreground="#B0B0B0" Margin="0,5,0,0"/>
                            <TextBlock Text="• Gamer (850GB)" FontSize="10" Foreground="#B0B0B0"/>
                            <TextBlock Text="• Studio (450GB)" FontSize="10" Foreground="#B0B0B0"/>
                            <TextBlock Text="• OneDrive (400GB)" FontSize="10" Foreground="#B0B0B0"/>
                            <TextBlock Text="• Recovery (100GB)" FontSize="10" Foreground="#B0B0B0"/>
                            <TextBlock Text="📊 4TB Total | 95% utilized" FontSize="10" Foreground="#FFB900" FontWeight="Bold" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Cloud Integration -->
                <TextBlock Text="Cloud Services" Style="{StaticResource HeaderText}" Margin="0,20,0,15"/>
                
                <Border Background="#252526" CornerRadius="8" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="☁️ Azure DevOps&#10;Azure Container Registry&#10;Azure Cloud Shell" FontSize="10" Foreground="#B0B0B0" TextAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="☁️ AWS EC2&#10;AWS S3&#10;AWS Lambda" FontSize="10" Foreground="#B0B0B0" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="☁️ GCP Compute&#10;GCP Storage&#10;GCP Functions" FontSize="10" Foreground="#B0B0B0" TextAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Footer -->
                <StackPanel Margin="0,40,0,20" HorizontalAlignment="Center">
                    <TextBlock Text="Monado Blade v2.0 | 8.7x Performance Speedup | Production Ready" 
                               FontSize="12" Foreground="#B0B0B0" TextAlignment="Center"/>
                    <TextBlock Text="© 2026 HELIOS Corporation | Proprietary" 
                               FontSize="10" Foreground="#696969" TextAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
