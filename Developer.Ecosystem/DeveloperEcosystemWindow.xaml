<Window x:Class="MonadoBlade.Developer.Ecosystem.GUI.DeveloperEcosystemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MONADO BLADE Developer Ecosystem" 
        Width="1600" Height="900"
        Background="#1E1E1E"
        Foreground="#E0E0E0"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <!-- Top Status Bar -->
        <Border Grid.ColumnSpan="2" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,0,0,1">
            <TextBlock x:Name="StatusTextBlock" 
                       Text="🚀 Initializing..." 
                       Foreground="#00D4FF" 
                       Padding="15"
                       FontSize="14"
                       FontWeight="Bold"/>
        </Border>

        <!-- Main Tab Control -->
        <TabControl Grid.Row="1" Grid.Column="0" Background="#252526" Foreground="#E0E0E0">
            <!-- Panel 1: Chat -->
            <TabItem Header="💬 Chat" Background="#3E3E42" Foreground="#E0E0E0">
                <Grid Background="#1E1E1E">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="ChatListBox" Grid.Row="0" Background="#252526" Foreground="#E0E0E0" Margin="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E1E" CornerRadius="8" Margin="5" Padding="10" 
                                        BorderBrush="#3E3E42" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss}" 
                                                   Foreground="#888888" FontSize="11"/>
                                        <TextBlock Text="{Binding Text}" Foreground="#E0E0E0" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding Provider}" Foreground="#00D4FF" FontSize="10" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="1" Margin="10" Orientation="Horizontal">
                        <TextBox x:Name="QueryInputTextBox" 
                                 Background="#3E3E42" 
                                 Foreground="#E0E0E0"
                                 Padding="10"
                                 Width="*"
                                 Margin="0,0,10,0"
                                 VerticalAlignment="Center"
                                 Text="Ask me anything..."/>
                        <Button x:Name="SendButton" 
                                Content="Send" 
                                Background="#007ACC" 
                                Foreground="White"
                                Padding="15,10"
                                Click="SendButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Panel 2: Context -->
            <TabItem Header="📋 Context" Background="#3E3E42" Foreground="#E0E0E0">
                <StackPanel Background="#1E1E1E" Padding="20" Margin="10">
                    <TextBlock Text="Language" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,5"/>
                    <ComboBox x:Name="LanguageComboBox" Background="#3E3E42" Foreground="#E0E0E0" Margin="0,0,0,15"/>

                    <TextBlock Text="Project Type" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ProjectTypeComboBox" Background="#3E3E42" Foreground="#E0E0E0" Margin="0,0,0,15"/>

                    <TextBlock Text="Analysis" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,5"/>
                    <TextBox Background="#3E3E42" Foreground="#E0E0E0" Height="150" 
                             Text="Enter code snippet or description for analysis..." 
                             TextWrapping="Wrap" Padding="10" Margin="0,0,0,15"/>

                    <Button Content="Analyze" Background="#007ACC" Foreground="White" Padding="10,8"/>
                </StackPanel>
            </TabItem>

            <!-- Panel 3: Output -->
            <TabItem Header="📤 Output" Background="#3E3E42" Foreground="#E0E0E0">
                <TextBox x:Name="OutputTextBox" 
                         Background="#252526" 
                         Foreground="#E0E0E0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         Padding="15"
                         Margin="10"/>
            </TabItem>

            <!-- Panel 4: Settings -->
            <TabItem Header="⚙️  Settings" Background="#3E3E42" Foreground="#E0E0E0">
                <StackPanel Background="#1E1E1E" Padding="20" Margin="10">
                    <TextBlock x:Name="SettingsStatusTextBlock" Foreground="#00D4FF" Margin="0,0,0,15" Text="Ready"/>

                    <TextBlock Text="AI Model" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ModelSelectionComboBox" 
                              Background="#3E3E42" 
                              Foreground="#E0E0E0" 
                              Margin="0,0,0,15"
                              SelectionChanged="ModelSelectionComboBox_SelectionChanged"/>

                    <TextBlock Text="Temperature" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Slider x:Name="TemperatureSlider" Width="200" Minimum="0" Maximum="1" Value="0.7"
                                Background="#3E3E42" Margin="0,0,10,0"
                                ValueChanged="TemperatureSlider_ValueChanged"/>
                        <TextBlock x:Name="TemperatureValueLabel" Text="0.70" Foreground="#E0E0E0"/>
                    </StackPanel>

                    <TextBlock Text="Max Tokens" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Slider x:Name="MaxTokensSlider" Width="200" Minimum="128" Maximum="4096" Value="2048"
                                Background="#3E3E42" Margin="0,0,10,0"
                                ValueChanged="MaxTokensSlider_ValueChanged"/>
                        <TextBlock x:Name="MaxTokensValueLabel" Text="2048" Foreground="#E0E0E0"/>
                    </StackPanel>

                    <CheckBox Content="Offline Mode (Hermes only)" Foreground="#E0E0E0" Margin="0,0,0,15"/>
                    <CheckBox Content="GPU Acceleration" Foreground="#E0E0E0" IsChecked="True" Margin="0,0,0,15"/>
                </StackPanel>
            </TabItem>

            <!-- Panel 5: History -->
            <TabItem Header="📚 History" Background="#3E3E42" Foreground="#E0E0E0">
                <Grid Background="#1E1E1E">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="HistoryListBox" Grid.Row="0" Background="#252526" Foreground="#E0E0E0" Margin="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E1E" CornerRadius="8" Margin="5" Padding="10">
                                    <TextBlock Text="{Binding Text}" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10">
                        <Button x:Name="LoadHistoryButton" 
                                Content="Load History" 
                                Background="#007ACC" 
                                Foreground="White"
                                Padding="10,8"
                                Margin="0,0,10,0"
                                Click="LoadHistoryButton_Click"/>
                        <Button x:Name="ClearHistoryButton" 
                                Content="Clear History" 
                                Background="#D13438" 
                                Foreground="White"
                                Padding="10,8"
                                Click="ClearHistoryButton_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="HistoryStatusTextBlock" Grid.Row="1" Foreground="#888888" Margin="100,10,0,0" VerticalAlignment="Center"/>
                </Grid>
            </TabItem>

            <!-- Panel 6: Tools -->
            <TabItem Header="🔧 Tools" Background="#3E3E42" Foreground="#E0E0E0">
                <ScrollViewer Background="#1E1E1E">
                    <StackPanel Padding="20" Margin="10">
                        <Border Background="#252526" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#3E3E42" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Git Commands" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,10"/>
                                <TextBox x:Name="GitCommandTextBox" Background="#3E3E42" Foreground="#E0E0E0" Padding="10" Margin="0,0,0,10"/>
                                <Button Content="Execute Git" Background="#007ACC" Foreground="White" Padding="10,8" Click="ExecuteGitCommand_Click"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#252526" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#3E3E42" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Docker Commands" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,10"/>
                                <TextBox x:Name="DockerCommandTextBox" Background="#3E3E42" Foreground="#E0E0E0" Padding="10" Margin="0,0,0,10"/>
                                <Button Content="Execute Docker" Background="#007ACC" Foreground="White" Padding="10,8" Click="ExecuteDockerCommand_Click"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#252526" CornerRadius="8" Padding="15" BorderBrush="#3E3E42" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="NPM Commands" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,10"/>
                                <TextBox x:Name="NpmCommandTextBox" Background="#3E3E42" Foreground="#E0E0E0" Padding="10" Margin="0,0,0,10"/>
                                <Button Content="Execute NPM" Background="#007ACC" Foreground="White" Padding="10,8" Click="ExecuteNpmCommand_Click"/>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="ToolsOutputTextBlock" Foreground="#888888" Margin="0,15,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Panel 7: WSL2 -->
            <TabItem Header="🖥️  WSL2" Background="#3E3E42" Foreground="#E0E0E0">
                <Grid Background="#1E1E1E">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="15" Margin="10">
                        <Button Content="Launch Terminal" Background="#007ACC" Foreground="White" Padding="10,8" Margin="0,0,10,0" Click="LaunchTerminalButton_Click"/>
                        <Button Content="Refresh Distros" Background="#107C10" Foreground="White" Padding="10,8" Margin="0,0,10,0" Click="RefreshDistrosButton_Click"/>
                        <Button Content="Mount Filesystem" Background="#107C10" Foreground="White" Padding="10,8" Click="MountFileSystemButton_Click"/>
                    </StackPanel>

                    <ListBox x:Name="DistroListBox" Grid.Row="1" Background="#252526" Foreground="#E0E0E0" Margin="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E1E" CornerRadius="8" Margin="5" Padding="10" BorderBrush="#3E3E42" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#00D4FF"/>
                                        <TextBlock Text="{Binding Version, StringFormat=Version: {0}}" Foreground="#E0E0E0" Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding Status, StringFormat=Status: {0}}" Foreground="#888888" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock x:Name="WSL2StatusTextBlock" Grid.Row="1" Foreground="#888888" Margin="20" VerticalAlignment="Bottom"/>
                </Grid>
            </TabItem>

            <!-- Panel 8: DevDrive -->
            <TabItem Header="💾 DevDrive" Background="#3E3E42" Foreground="#E0E0E0">
                <StackPanel Background="#1E1E1E" Padding="20" Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="Optimize" Background="#107C10" Foreground="White" Padding="10,8" Margin="0,0,10,0" Click="OptimizeDevDriveButton_Click"/>
                        <Button Content="Backup" Background="#107C10" Foreground="White" Padding="10,8" Margin="0,0,10,0" Click="BackupDevDriveButton_Click"/>
                        <Button Content="Refresh Status" Background="#007ACC" Foreground="White" Padding="10,8" Click="RefreshDevDriveStatusButton_Click"/>
                    </StackPanel>

                    <Border Background="#252526" CornerRadius="8" Padding="15" BorderBrush="#3E3E42" BorderThickness="1">
                        <TextBlock x:Name="DevDriveStatusTextBlock" 
                                   Foreground="#00D4FF" 
                                   TextWrapping="Wrap"
                                   Text="📍 Mount: E:&#10;📊 Total: 400.00 GB&#10;💿 Free: 350.00 GB&#10;⚡ Boost: 40%"/>
                    </Border>

                    <TextBlock Text="ReFS Optimization Active" Foreground="#00D4FF" Margin="0,20,0,0" FontWeight="Bold"/>
                    <TextBlock Text="Performance boost: 40% faster than NTFS" Foreground="#888888" Margin="0,5,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Right Sidebar: Status Panel -->
        <Border Grid.Row="1" Grid.Column="1" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1,0,0,0">
            <ScrollViewer Padding="15">
                <StackPanel>
                    <TextBlock Text="System Status" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,15" FontSize="14"/>

                    <Border Background="#1E1E1E" CornerRadius="8" Padding="10" Margin="0,0,0,10" BorderBrush="#3E3E42" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Hermes LLM" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,5"/>
                            <TextBlock Text="✅ Running" Foreground="#00D4FF"/>
                            <TextBlock Text="Models: 7B, 13B, 70B" Foreground="#888888" FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock Text="Latency: 150-300ms" Foreground="#888888" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1E1E1E" CornerRadius="8" Padding="10" Margin="0,0,0,10" BorderBrush="#3E3E42" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="GitHub Copilot" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,5"/>
                            <TextBlock Text="🔗 Connected" Foreground="#107C10"/>
                            <TextBlock Text="Fallback ready" Foreground="#888888" FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock Text="Network-based" Foreground="#888888" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1E1E1E" CornerRadius="8" Padding="10" Margin="0,0,0,10" BorderBrush="#3E3E42" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="WSL2" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,5"/>
                            <TextBlock Text="✅ Initialized" Foreground="#00D4FF"/>
                            <TextBlock Text="Ubuntu 24.04" Foreground="#888888" FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock Text="Fedora 40" Foreground="#888888" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1E1E1E" CornerRadius="8" Padding="10" BorderBrush="#3E3E42" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="DevDrive (ReFS)" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,5"/>
                            <TextBlock Text="📍 E: Drive" Foreground="#00D4FF"/>
                            <TextBlock Text="Boost: +40%" Foreground="#107C10" FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock Text="Optimized" Foreground="#888888" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Bottom Footer -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,1,0,0">
            <TextBlock Text="MONADO BLADE Developer Ecosystem | Dual-AI Fallback Strategy Enabled | Ready for Production" 
                       Foreground="#888888" 
                       Padding="15"
                       FontSize="11"/>
        </Border>
    </Grid>
</Window>
