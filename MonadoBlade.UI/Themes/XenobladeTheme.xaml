<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=netstandard">

    <!-- ============================================
         MONADO BLADE - XENOBLADE THEME
         Dark theme with cyan accents
         ============================================ -->

    <!-- PRIMARY COLORS -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#00D9FF"/>
    <Color x:Key="PrimaryColor">#00D9FF</Color>
    
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0A0E27"/>
    <Color x:Key="BackgroundColor">#0A0E27</Color>
    
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1A1F3A"/>
    <Color x:Key="SurfaceColor">#1A1F3A</Color>

    <!-- SEMANTIC COLORS -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#00FF41"/>
    <Color x:Key="SuccessColor">#00FF41</Color>
    
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF0055"/>
    <Color x:Key="ErrorColor">#FF0055</Color>
    
    <SolidColorBrush x:Key="WarningBrush" Color="#FFB800"/>
    <Color x:Key="WarningColor">#FFB800</Color>
    
    <SolidColorBrush x:Key="InfoBrush" Color="#00D9FF"/>
    <Color x:Key="InfoColor">#00D9FF</Color>

    <!-- NEUTRAL COLORS -->
    <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
    <Color x:Key="TextColor">#FFFFFF</Color>
    
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#999999"/>
    <Color x:Key="TextSecondaryColor">#999999</Color>
    
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#666666"/>
    <Color x:Key="TextTertiaryColor">#666666</Color>
    
    <SolidColorBrush x:Key="BorderBrush" Color="#333333"/>
    <Color x:Key="BorderColor">#333333</Color>

    <!-- TYPOGRAPHY SIZES (XAML uses double for font sizes) -->
    <system:Double x:Key="FontSizeH1">32</system:Double>
    <system:Double x:Key="FontSizeH2">24</system:Double>
    <system:Double x:Key="FontSizeH3">18</system:Double>
    <system:Double x:Key="FontSizeBody">14</system:Double>
    <system:Double x:Key="FontSizeSmall">12</system:Double>
    <system:Double x:Key="FontSizeMono">12</system:Double>

    <!-- FONT FAMILY -->
    <FontFamily x:Key="FontFamilyDefault">Inter, Segoe UI, Tahoma</FontFamily>
    <FontFamily x:Key="FontFamilyMono">Inconsolata, Courier New, Monospace</FontFamily>

    <!-- FONT WEIGHTS -->
    <FontWeight x:Key="FontWeightBold">Bold</FontWeight>
    <FontWeight x:Key="FontWeightSemiBold">SemiBold</FontWeight>
    <FontWeight x:Key="FontWeightRegular">Regular</FontWeight>

    <!-- SPACING GRID (8px base) -->
    <system:Double x:Key="SpacingXS">4</system:Double>
    <system:Double x:Key="SpacingSM">8</system:Double>
    <system:Double x:Key="SpacingMD">16</system:Double>
    <system:Double x:Key="SpacingLG">24</system:Double>
    <system:Double x:Key="SpacingXL">32</system:Double>
    <system:Double x:Key="Spacing2XL">48</system:Double>

    <!-- COMPONENT SIZES -->
    <system:Double x:Key="ButtonHeight">36</system:Double>
    <system:Double x:Key="ButtonPaddingH">16</system:Double>
    <system:Double x:Key="ButtonPaddingV">8</system:Double>
    
    <system:Double x:Key="InputHeight">32</system:Double>
    <system:Double x:Key="InputPaddingH">12</system:Double>
    <system:Double x:Key="InputPaddingV">8</system:Double>
    
    <system:Double x:Key="CardPaddingSM">16</system:Double>
    <system:Double x:Key="CardPaddingMD">24</system:Double>
    
    <system:Double x:Key="IconSize">16</system:Double>

    <!-- BORDER RADIUS -->
    <CornerRadius x:Key="CornerRadiusSharp">4</CornerRadius>
    <CornerRadius x:Key="CornerRadiusRound">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusPill">20</CornerRadius>

    <!-- BORDER THICKNESS -->
    <Thickness x:Key="BorderThicknessThin">1</Thickness>
    <Thickness x:Key="BorderThicknessFocus">2</Thickness>
    <Thickness x:Key="PaddingButton">8,16</Thickness>
    <Thickness x:Key="PaddingInput">8,12</Thickness>
    <Thickness x:Key="PaddingCardSM">16</Thickness>
    <Thickness x:Key="PaddingCardMD">24</Thickness>

    <!-- BRUSH DEFINITIONS FOR SHADOWS -->
    <system:String x:Key="DropShadowElevation1">0 2px 4px #1A000000</system:String>
    <system:String x:Key="DropShadowElevation2">0 4px 8px #33000000</system:String>
    <system:String x:Key="DropShadowElevation3">0 8px 16px #4D000000</system:String>
    <system:String x:Key="GlowCyan">0 0 16px #4D00D9FF</system:String>

    <!-- LINE HEIGHTS (as multipliers for use in TextBlock) -->
    <system:Double x:Key="LineHeightH1">1.2</system:Double>
    <system:Double x:Key="LineHeightH2">1.3</system:Double>
    <system:Double x:Key="LineHeightH3">1.4</system:Double>
    <system:Double x:Key="LineHeightBody">1.6</system:Double>
    <system:Double x:Key="LineHeightSmall">1.5</system:Double>

    <!-- ANIMATION DURATIONS (in milliseconds) -->
    <Duration x:Key="AnimationDurationQuick">0:0:0.150</Duration>
    <Duration x:Key="AnimationDurationStandard">0:0:0.200</Duration>
    <Duration x:Key="AnimationDurationSlow">0:0:0.300</Duration>
    <Duration x:Key="AnimationDurationExtraSlow">0:0:0.500</Duration>

    <!-- BUTTON STYLES -->
    <Style x:Key="ButtonPrimary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="Height" Value="{StaticResource ButtonHeight}"/>
        <Setter Property="Padding" Value="{StaticResource PaddingButton}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="4" Background="{TemplateBinding Background}" 
                            BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ButtonSecondary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Height" Value="{StaticResource ButtonHeight}"/>
        <Setter Property="Padding" Value="{StaticResource PaddingButton}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="4" Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ButtonDanger" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Height" Value="{StaticResource ButtonHeight}"/>
        <Setter Property="Padding" Value="{StaticResource PaddingButton}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="4" Background="{TemplateBinding Background}" 
                            BorderBrush="{StaticResource ErrorBrush}" BorderThickness="0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TEXTBOX (INPUT) STYLE -->
    <Style x:Key="TextFieldStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Height" Value="{StaticResource InputHeight}"/>
        <Setter Property="Padding" Value="{StaticResource PaddingInput}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Name="Bd" CornerRadius="4" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CARD STYLE -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="{StaticResource PaddingCardSM}"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <!-- TEXT STYLES -->
    <Style x:Key="TextH1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeH1}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightBold}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="LineHeight" Value="{StaticResource LineHeightH1}"/>
    </Style>

    <Style x:Key="TextH2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeH2}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightBold}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="LineHeight" Value="{StaticResource LineHeightH2}"/>
    </Style>

    <Style x:Key="TextH3" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeH3}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="LineHeight" Value="{StaticResource LineHeightH3}"/>
    </Style>

    <Style x:Key="TextBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightRegular}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="LineHeight" Value="{StaticResource LineHeightBody}"/>
    </Style>

    <Style x:Key="TextSmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightRegular}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="LineHeight" Value="{StaticResource LineHeightSmall}"/>
    </Style>

    <Style x:Key="TextMono" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeMono}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightRegular}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
    </Style>

</ResourceDictionary>
