<UserControl x:Class="MonadoBlade.UI.Components.Input.Toggle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <StackPanel Orientation="Horizontal" Margin="0,0,0,16" VerticalAlignment="Center">
        <TextBlock Text="Enable Feature:" Style="{DynamicResource TextBody}" Margin="0,0,16,0"/>
        <CheckBox IsChecked="True" 
                  Foreground="{DynamicResource PrimaryBrush}"
                  Margin="0"
                  VerticalAlignment="Center"/>
    </StackPanel>
</UserControl>
