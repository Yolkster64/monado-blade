<UserControl x:Class="MonadoBlade.UI.Components.Input.TextField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <StackPanel Margin="0,0,0,16">
        <TextBlock Text="Input Label" Style="{DynamicResource TextBody}" Margin="0,0,0,8"/>
        <TextBox Style="{DynamicResource TextFieldStyle}" 
                 Text="Enter text here..."
                 Foreground="{DynamicResource TextBrush}"/>
        <TextBlock Text="Helper text or validation message" 
                   Style="{DynamicResource TextSmall}" 
                   Margin="0,8,0,0"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
    </StackPanel>
</UserControl>
