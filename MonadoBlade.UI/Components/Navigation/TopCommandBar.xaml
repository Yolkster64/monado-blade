<UserControl x:Class="MonadoBlade.UI.Components.Navigation.TopCommandBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource SurfaceBrush}"
             Height="50">
    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal" Margin="16" VerticalAlignment="Center">
            <TextBlock Text="Commands" Style="{DynamicResource TextH3}" Margin="0,0,16,0"/>
            <Button Style="{DynamicResource ButtonSecondary}" Margin="0,0,8,0">Add</Button>
            <Button Style="{DynamicResource ButtonSecondary}" Margin="0,0,8,0">Edit</Button>
            <Button Style="{DynamicResource ButtonDanger}">Delete</Button>
        </StackPanel>
    </Border>
</UserControl>
