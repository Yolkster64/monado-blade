<UserControl x:Class="MonadoBlade.UI.Components.DataDisplay.MetricBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             Width="180" Height="120">
    <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,16">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16">
            <TextBlock Text="Metric" Style="{DynamicResource TextSmall}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
            <TextBlock Text="9,876" Style="{DynamicResource TextH1}" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="↑ 12% from last month" Style="{DynamicResource TextSmall}" Foreground="{DynamicResource SuccessBrush}"/>
        </StackPanel>
    </Border>
</UserControl>
