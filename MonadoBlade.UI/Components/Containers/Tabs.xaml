<UserControl x:Class="MonadoBlade.UI.Components.Containers.Tabs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Border Style="{DynamicResource CardStyle}">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="16,16,16,0">
                <Button Content="Tab 1" Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource BackgroundBrush}" Padding="16,8" Margin="0,0,8,0"/>
                <Button Content="Tab 2" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1" Padding="16,8" Margin="0,0,8,0"/>
                <Button Content="Tab 3" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1" Padding="16,8"/>
            </StackPanel>
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,16,0,0" Padding="16">
                <TextBlock Text="Tab content goes here" Style="{DynamicResource TextBody}"/>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
