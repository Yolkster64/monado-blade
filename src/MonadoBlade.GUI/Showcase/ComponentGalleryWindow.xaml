<Window x:Class="MonadoBlade.GUI.Showcase.ComponentGalleryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Monado Blade Component Gallery"
        Width="1000"
        Height="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <StackPanel Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Component Gallery"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,20" />
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Button Content="Primary" Click="OnPrimaryButtonClick" Margin="0,0,10,0" Padding="10,5" />
                <Button Content="Secondary" Click="OnSecondaryButtonClick" Margin="0,0,10,0" Padding="10,5" />
                <Button Content="Danger" Click="OnDangerButtonClick" Margin="0,0,10,0" Padding="10,5" />
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Button Content="Toggle Theme" Click="OnToggleTheme" Margin="0,0,10,0" Padding="10,5" />
                <Button Content="Show Animations" Click="OnShowAnimations" Margin="0,0,10,0" Padding="10,5" />
                <Button Content="Test Responsive" Click="OnTestResponsive" Padding="10,5" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
