<![CDATA[<!-- MONADO BLADE v3.4.0 - ANIMATION STORYBOARDS -->
<!-- File: src/MonadoBlade.GUI/Themes/Animations.xaml -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- FADE IN STORYBOARD -->
    <Storyboard x:Key="FadeInStoryboard">
        <DoubleAnimation 
            Storyboard.TargetProperty="Opacity"
            From="0" To="1" 
            Duration="0:0:0.3"
            EasingFunction="{StaticResource CubicEaseOut}"/>
    </Storyboard>

    <!-- FADE OUT STORYBOARD -->
    <Storyboard x:Key="FadeOutStoryboard">
        <DoubleAnimation 
            Storyboard.TargetProperty="Opacity"
            From="1" To="0" 
            Duration="0:0:0.3"
            EasingFunction="{StaticResource CubicEaseIn}"/>
    </Storyboard>

    <!-- SCALE UP STORYBOARD (Hover) -->
    <Storyboard x:Key="ScaleUpStoryboard">
        <DoubleAnimation 
            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
            From="1.0" To="1.05"
            Duration="0:0:0.15"
            EasingFunction="{StaticResource CubicEaseOut}"/>
        <DoubleAnimation 
            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
            From="1.0" To="1.05"
            Duration="0:0:0.15"
            EasingFunction="{StaticResource CubicEaseOut}"/>
    </Storyboard>

    <!-- SCALE DOWN STORYBOARD (Leave) -->
    <Storyboard x:Key="ScaleDownStoryboard">
        <DoubleAnimation 
            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
            From="1.05" To="1.0"
            Duration="0:0:0.15"
            EasingFunction="{StaticResource CubicEaseIn}"/>
        <DoubleAnimation 
            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
            From="1.05" To="1.0"
            Duration="0:0:0.15"
            EasingFunction="{StaticResource CubicEaseIn}"/>
    </Storyboard>

    <!-- SLIDE IN FROM TOP STORYBOARD -->
    <Storyboard x:Key="SlideInTopStoryboard">
        <ThicknessAnimation 
            Storyboard.TargetProperty="Margin"
            From="0,-50,0,0" To="0,0,0,0"
            Duration="0:0:0.3"
            EasingFunction="{StaticResource CubicEaseOut}"/>
    </Storyboard>

    <!-- SLIDE IN FROM BOTTOM STORYBOARD -->
    <Storyboard x:Key="SlideInBottomStoryboard">
        <ThicknessAnimation 
            Storyboard.TargetProperty="Margin"
            From="0,50,0,0" To="0,0,0,0"
            Duration="0:0:0.3"
            EasingFunction="{StaticResource CubicEaseOut}"/>
    </Storyboard>

    <!-- SLIDE IN FROM LEFT STORYBOARD -->
    <Storyboard x:Key="SlideInLeftStoryboard">
        <ThicknessAnimation 
            Storyboard.TargetProperty="Margin"
            From="-50,0,0,0" To="0,0,0,0"
            Duration="0:0:0.3"
            EasingFunction="{StaticResource CubicEaseOut}"/>
    </Storyboard>

    <!-- SLIDE IN FROM RIGHT STORYBOARD -->
    <Storyboard x:Key="SlideInRightStoryboard">
        <ThicknessAnimation 
            Storyboard.TargetProperty="Margin"
            From="50,0,0,0" To="0,0,0,0"
            Duration="0:0:0.3"
            EasingFunction="{StaticResource CubicEaseOut}"/>
    </Storyboard>

    <!-- SHIMMER STORYBOARD (Loading) -->
    <Storyboard x:Key="ShimmerStoryboard" RepeatBehavior="Forever">
        <DoubleAnimation 
            Storyboard.TargetProperty="Opacity"
            From="0.3" To="1.0" To="0.3"
            Duration="0:0:1"
            EasingFunction="{StaticResource SineEaseInOut}"/>
    </Storyboard>

    <!-- PULSE STORYBOARD (Alert) -->
    <Storyboard x:Key="PulseStoryboard" RepeatBehavior="3x">
        <DoubleAnimation 
            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
            From="1.0" To="1.1" To="1.0"
            Duration="0:0:0.4"
            EasingFunction="{StaticResource QuadraticEaseInOut}"/>
        <DoubleAnimation 
            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
            From="1.0" To="1.1" To="1.0"
            Duration="0:0:0.4"
            EasingFunction="{StaticResource QuadraticEaseInOut}"/>
    </Storyboard>

    <!-- ROTATION STORYBOARD (Spinner) -->
    <Storyboard x:Key="RotationStoryboard" RepeatBehavior="Forever">
        <DoubleAnimation 
            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
            From="0" To="360"
            Duration="0:0:1"
            EasingFunction="{StaticResource LinearEase}"/>
    </Storyboard>

    <!-- EASING FUNCTIONS -->
    <CubicEase x:Key="CubicEaseOut" EasingMode="EaseOut"/>
    <CubicEase x:Key="CubicEaseIn" EasingMode="EaseIn"/>
    <CubicEase x:Key="CubicEaseInOut" EasingMode="EaseInOut"/>
    <SineEase x:Key="SineEaseInOut" EasingMode="EaseInOut"/>
    <QuadraticEase x:Key="QuadraticEaseInOut" EasingMode="EaseInOut"/>
    <LinearEase x:Key="LinearEase"/>

</ResourceDictionary>
]]>